<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
    MyMemory Uploader Daemon (#178)

    Bevakar lokala Assets/ och pushar pre-parsad text till cloud-servern
    via REST (#165). State i SQLite (~/Library/Application Support/MyMemory/uploader_state.db).

    Förutsätter:
    - my_mem_config.yaml innehåller cloud.api_url och cloud.pat
    - Asset-mappar finns under paths.asset_store

    Install: launchctl load ~/Library/LaunchAgents/com.mymemory.uploader.plist
    Uninstall: launchctl unload ~/Library/LaunchAgents/com.mymemory.uploader.plist
    Status: launchctl list | grep mymemory.uploader
    -->

    <key>Label</key>
    <string>com.mymemory.uploader</string>

    <key>ProgramArguments</key>
    <array>
        <string>__VENV_PYTHON__</string>
        <string>__PROJECT_ROOT__/services/uploader/daemon.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>WorkingDirectory</key>
    <string>__PROJECT_ROOT__</string>

    <key>StandardOutPath</key>
    <string>__HOME__/Library/Logs/MyMemory/uploader.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/Library/Logs/MyMemory/uploader.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <key>PYTHONPATH</key>
        <string>__PROJECT_ROOT__</string>
    </dict>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>

    <key>Nice</key>
    <integer>10</integer>
</dict>
</plist>
